# Normalizar todos los archivos de texto a LF (Line Feed)
# Esto asegura consistencia cross-platform

# Archivos de código fuente
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.svg text eol=lf

# Configuración
*.config.js text eol=lf
*.config.ts text eol=lf
.gitignore text eol=lf
.editorconfig text eol=lf
.gitattributes text eol=lf

# Archivos de documentación
*.txt text eol=lf
*.rtf text eol=lf

# Archivos de scripts
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf

# Archivos de configuración de herramientas
*.eslintrc* text eol=lf
*.prettierrc* text eol=lf
*.babelrc* text eol=lf
tsconfig*.json text eol=lf
package*.json text eol=lf
pnpm-workspace.yaml text eol=lf

# Archivos binarios - no normalizar
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar.gz binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary

# Mantener LF en archivos de lock (si existen)
package-lock.json text eol=lf
yarn.lock text eol=lf
pnpm-lock.yaml text eol=lf

